{
  "name": "@tellus-ai/audio-sdk",
  "version": "0.1.6",
  "description": "Tellus Audio SDK wrapper for Electron and Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tellus-ai/tellus-audio-sdk.git"
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/runtime/engine-runtime.js",
    "dist/runtime/engine-runtime.d.ts",
    "dist/platform/asset-key.js",
    "dist/platform/asset-key.d.ts",
    "dist/installer/install-binary.js",
    "dist/installer/install-binary.d.ts",
    "dist/installer/install-binary-cli.js",
    "dist/installer/install-binary-cli.d.ts",
    "dist/installer/check-binary.js",
    "dist/installer/check-binary.d.ts",
    "dist/installer/check-binary-cli.js",
    "dist/installer/check-binary-cli.d.ts",
    "README.md",
    "LICENSE",
    "release-assets.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:binary": "node dist/installer/check-binary-cli.js",
    "check:js": "npm run build && find dist -name '*.js' -print0 | xargs -0 -n1 node --check",
    "check:package": "npm run build && node dist/installer/check-package-contents.js",
    "check:postinstall-build": "node scripts/check-postinstall-build-command.js",
    "install:binary": "node dist/installer/install-binary-cli.js",
    "prepare": "npm run build",
    "postinstall": "node -e \"const fs=require('node:fs');const cp=require('node:child_process');const runBuild=()=>{const npmExec=process.env.npm_execpath;if(npmExec){cp.execFileSync(process.execPath,[npmExec,'run','build'],{stdio:'inherit'});return;}if(process.platform==='win32'){cp.execFileSync('cmd.exe',['/d','/s','/c','npm run build'],{stdio:'inherit'});return;}cp.execFileSync('npm',['run','build'],{stdio:'inherit'});};if(!fs.existsSync('dist/installer/install-binary-cli.js')&&fs.existsSync('src/installer/install-binary-cli.ts'))runBuild();cp.execFileSync(process.execPath,['dist/installer/install-binary-cli.js'],{stdio:'inherit'});\""
  },
  "engines": {
    "node": ">= 18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
